# =============================================================================
# ARBAL — Environment Variables
# Copy to .env and fill in real values before running.
# =============================================================================

# ---- Database ----
# PostgreSQL connection string (used by Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/arbal_db"

# ---- Authentication ----
# JWT secret for signing access tokens (short-lived, 15 min).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# MUST be at least 32 characters for security.
JWT_SECRET="CHANGE_ME_USE_STRONG_SECRET_MIN_64_CHARS"

# JWT secret for signing refresh tokens (long-lived, 7 days).
# MUST be different from JWT_SECRET.
JWT_REFRESH_SECRET="CHANGE_ME_DIFFERENT_STRONG_SECRET_MIN_64_CHARS"

# ---- Google AI (optional, for OCR) ----
# Required for Gemini AI API calls.
GEMINI_API_KEY=""

# ---- Server ----
# Backend port (default: 3001)
PORT=3001

# Node environment: "development" or "production"
NODE_ENV=development

# ---- CORS ----
# Comma-separated list of allowed origins. Defaults to localhost:3000 in development.
# CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ---- OCR Service (optional) ----
# URL of the Python OCR microservice
OCR_SERVICE_URL="http://localhost:8000"
# Internal shared token for backend → OCR service authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OCR_INTERNAL_TOKEN="CHANGE_ME_GENERATE_RANDOM_TOKEN"

# ---- File Storage ----
# Absolute path for uploaded files. Defaults to backend/uploads/ if not set.
# UPLOADS_DIR="/var/data/arbal/uploads"

# ---- App URL ----
# The URL where this app is hosted.
APP_URL="http://localhost:3000"

# ---- Backup — Google Drive (optional) ----
# Service Account JSON key (inline, one line — copy the entire JSON content)
# GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...",...}'

# Google Drive folder ID where backups will be stored
# GOOGLE_DRIVE_FOLDER_ID="1AbCdEfGhIjKlMnOpQrStUvWxYz"
