# =============================================================================
# ARBAL - Production Environment Example
# Target public domain: https://arsip.insanmustaqbal.or.id
# Reverse proxy: Zoraxy
# =============================================================================

# ---- Public App ----
APP_URL=https://arsip.insanmustaqbal.or.id
CORS_ORIGINS=https://arsip.insanmustaqbal.or.id
NODE_ENV=production
FRONTEND_PORT=3000

# ---- Database ----
POSTGRES_USER=arbal_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
POSTGRES_DB=arbal_db
DATABASE_URL=postgresql://arbal_admin:CHANGE_ME_STRONG_DATABASE_PASSWORD@db:5432/arbal_db

# ---- Backend ----
PORT=3001
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET_MIN_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_STRONG_RANDOM_SECRET_MIN_64_CHARS
APP_VERSION=1.0.0
APP_BUILD=production
MAX_BACKUPS=30
RETENTION_DAYS=90

# ---- Storage ----
# Leave unset to use mounted defaults inside the backend container.
# UPLOADS_DIR=/app/uploads
# BACKUPS_DIR=/app/backups

# ---- OCR (optional) ----
# If OCR container is enabled, keep the default internal URL below.
OCR_SERVICE_URL=http://ocr:8000
OCR_INTERNAL_TOKEN=CHANGE_ME_RANDOM_INTERNAL_TOKEN
OCR_CORS_ORIGIN=http://backend:3001
OCR_LOG_LEVEL=INFO
PADDLE_LANG=id
PADDLE_USE_GPU=false

# ---- Integrations (optional) ----
GEMINI_API_KEY=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_FOLDER_ID=
