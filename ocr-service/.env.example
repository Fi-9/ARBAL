# ARBAL OCR Service — Environment Configuration
# Copy to .env and adjust values for your environment.

# Server
PORT=8000

# CORS — NestJS backend origin (must match your backend URL)
CORS_ORIGIN=http://localhost:3001

# PaddleOCR settings
PADDLE_LANG=id
PADDLE_USE_GPU=false

# Logging
LOG_LEVEL=INFO
